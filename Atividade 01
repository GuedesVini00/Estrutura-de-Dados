#include <stdio.h>

int fibonat(int n){
    
    if(n==0) return 0;
    else if(n<1){
        return 1;
    }else{
        return fibonat(n-1)+fibonat(n-2);
        
    }
}

int main()
{
    printf("%i", fibonat(7));
    return 0;
}

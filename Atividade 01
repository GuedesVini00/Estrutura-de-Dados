#include <stdio.h>

int exponencial (int x, int y){
    if(y==0){
        return 1;
    }else{
        return exponencial(x,y-1)*x;
    }
}

int main(){
    int n ;
    int x=0;
    int y=0;
    int i;
    printf("insira um número e seu expoente:");
    scanf("%i %i", &x , &y);
    printf("%i", exponencial(x,y));
    
}

